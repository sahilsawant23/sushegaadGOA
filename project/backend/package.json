{
  "name": "goa-backend",
  "version": "1.0.0",
  "description": "Backend server for Goa project with Express and MySQL",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:setup": "node scripts/setup-db.js",
    "db:check": "node scripts/check-db-schema.js",
    "seed:all": "npm run seed:destinations && npm run seed:tours && npm run seed:admin",
    "seed:destinations": "node scripts/seed-destinations.js",
    "seed:tours": "node scripts/seed-tours.js",
    "seed:admin": "node scripts/seed-admin.js",
    "create:admin": "node scripts/create-admin.js",
    "test:manual-login": "node scripts/test-admin-login.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
